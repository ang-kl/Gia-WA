# WhatsApp Cloud API
WA_PHONE_NUMBER_ID=
WA_BUSINESS_TOKEN=
WA_VERIFY_TOKEN=
WA_APP_SECRET=
WA_GRAPH_API_VERSION=v21.0

# Flows Data Channel (RSA-2048 keypair; public key uploaded to Meta)
FLOWS_PRIVATE_KEY_PEM=
FLOWS_PUBLIC_KEY_PEM=
FLOWS_PRIVATE_KEY_PASSPHRASE=

# AI providers (Llama only — D-1)
GROQ_API_KEY=
TOGETHER_API_KEY=
TAVILY_API_KEY=

# Optional Google integration (sanctuary tool)
GOOGLE_PLACES_API_KEY=

# Storage (separate DB number from any Telegram-side workload)
REDIS_URL=redis://localhost:6379/2

# Observability
LOG_LEVEL=info
PORT=3000
